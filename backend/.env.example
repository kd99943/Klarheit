# Spring Boot does not load this file automatically.
# Copy values into your shell, IDE run config, or CI secret store.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8081

# Local development defaults can use H2 with the local profile.
# Set these only when you want to run against MySQL instead.
DB_URL=jdbc:mysql://localhost:3306/lumina_optics?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=change-me
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

APP_JWT_SECRET=replace-with-a-base64-secret-at-least-32-bytes
APP_JWT_EXPIRATION_MILLIS=86400000

JPA_DDL_AUTO=validate
SQL_INIT_MODE=never
SQL_INIT_SCHEMA_LOCATIONS=classpath:schema.sql
APP_TIME_ZONE=UTC
