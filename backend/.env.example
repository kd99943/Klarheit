# Spring Boot does not load this file automatically.
# Copy values into your shell, IDE run config, or CI secret store.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8081

# MySQL configuration for local development
DB_URL=jdbc:mysql://localhost:3306/klarheit?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=change-me
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# Generate a secure key: openssl rand -base64 32
APP_JWT_SECRET=replace-with-a-base64-secret-at-least-32-bytes
APP_JWT_EXPIRATION_MILLIS=86400000

JPA_DDL_AUTO=validate
APP_TIME_ZONE=UTC

# Optional: Resend email service
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@klarheit.com

# Optional: Alipay sandbox
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# Optional: WeChat Pay
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# Payment callback signature verification (required for production)
# Generate a secure key: openssl rand -hex 32
PAYMENT_CALLBACK_SECRET=change-me-in-production

# SMS Configuration (Alibaba Cloud SMS)
# Provider: "mock" for development (logs codes to console), "alibaba" for production
SMS_PROVIDER=mock
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=Klarheit
SMS_TEMPLATE_CODE=

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
